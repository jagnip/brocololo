generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

enum CategoryType {
  MEAL_OCCASION
  RECIPE_TYPE
  PROTEIN
}

model Category {
  id      String       @id @default(cuid())
  name    String       @unique
  slug    String       @unique
  type    CategoryType
  recipes Recipe[]     @relation("category_recipes")

  @@map("categories")
  @@index([type])
}

enum PlannerMealType {
  BREAKFAST
  LUNCH
  DINNER
}

enum LogMealType {
  BREAKFAST
  LUNCH
  SNACK
  DINNER
}

enum LogPerson {
  PRIMARY
  SECONDARY
}

model Plan {
  id        String     @id @default(cuid())
  startDate DateTime   @map("start_date")
  endDate   DateTime   @map("end_date")
  createdAt DateTime   @default(now()) @map("created_at")
  slots     PlanSlot[]
  log       Log?
  shoppingList ShoppingList?

  @@map("plans")
}

model GroceryIngredient {
  id                    String @id @default(cuid())
  ingredientId          String @unique @map("ingredient_id")
  additionalInfo        String? @map("additional_info")
  substitutionsAllowed  Boolean @default(false) @map("substitutions_allowed")
  substitutionNote      String? @map("substitution_note")

  ingredient            Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  shoppingListItems     ShoppingListItem[]

  @@map("grocery_ingredients")
}

model ShoppingLayoutPreset {
  id        String   @id @default(cuid())
  name      String
  isBuiltIn Boolean  @default(false) @map("is_built_in")

  categoryOrders     ShoppingLayoutPresetCategory[]
  listsUsingAsActive ShoppingList[]

  @@map("shopping_layout_presets")
}

model ShoppingLayoutPresetCategory {
  id                   String @id @default(cuid())
  presetId             String @map("preset_id")
  ingredientCategoryId String @map("ingredient_category_id")
  position             Int

  preset             ShoppingLayoutPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  ingredientCategory IngredientCategory   @relation(fields: [ingredientCategoryId], references: [id], onDelete: Cascade)

  @@unique([presetId, ingredientCategoryId])
  @@index([presetId, position])
  @@map("shopping_layout_preset_categories")
}

model ShoppingList {
  id                   String   @id @default(cuid())
  planId               String   @unique @map("plan_id")
  activeLayoutPresetId String?  @map("active_layout_preset_id")
  createdAt            DateTime @default(now()) @map("created_at")

  plan                 Plan                  @relation(fields: [planId], references: [id], onDelete: Cascade)
  activeLayoutPreset   ShoppingLayoutPreset? @relation(fields: [activeLayoutPresetId], references: [id], onDelete: SetNull)
  items                ShoppingListItem[]

  @@map("shopping_lists")
}

model ShoppingListItem {
  id                   String   @id @default(cuid())
  shoppingListId       String   @map("shopping_list_id")
  groceryIngredientId  String?  @map("grocery_ingredient_id")
  ingredientCategoryId String   @map("ingredient_category_id")
  displayLabel         String   @map("display_label")
  unitId               String?  @map("unit_id")
  amount               Float?
  additionalInfo       String?  @map("additional_info")
  substitutionsAllowed Boolean  @default(false) @map("substitutions_allowed")
  substitutionNote     String?  @map("substitution_note")
  purchased            Boolean  @default(false)
  recipeAttribution    String?  @map("recipe_attribution")
  position             Int      @default(0)

  shoppingList       ShoppingList       @relation(fields: [shoppingListId], references: [id], onDelete: Cascade)
  groceryIngredient  GroceryIngredient? @relation(fields: [groceryIngredientId], references: [id], onDelete: SetNull)
  category           IngredientCategory @relation(fields: [ingredientCategoryId], references: [id], onDelete: Restrict)
  unit               Unit?              @relation(fields: [unitId], references: [id], onDelete: Restrict)

  @@index([shoppingListId, ingredientCategoryId, position])
  @@map("shopping_list_items")
}

model PlanSlot {
  id        String   @id @default(cuid())
  planId    String   @map("plan_id")
  date      DateTime @db.Date
  mealType  PlannerMealType @map("meal_type")
  recipeId  String?  @map("recipe_id")
  used      Boolean  @default(false)

  plan         Plan                  @relation(fields: [planId], references: [id], onDelete: Cascade)
  recipe       Recipe?               @relation("recipe_plan_slots", fields: [recipeId], references: [id], onDelete: Cascade)
  alternatives PlanSlotAlternative[]
  logEntryRecipes LogEntryRecipe[]

  @@index([planId])
  @@index([recipeId])
  @@map("plan_slots")
}

model PlanSlotAlternative {
  id         String @id @default(cuid())
  planSlotId String @map("plan_slot_id")
  recipeId   String @map("recipe_id")
  rank       Int

  planSlot PlanSlot @relation(fields: [planSlotId], references: [id], onDelete: Cascade)
  recipe   Recipe   @relation("recipe_alternatives", fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([planSlotId])
  @@index([recipeId])
  @@map("plan_slot_alternatives")
}

model Recipe {
  id           String     @id @default(cuid())
  name         String     @unique
  slug         String     @unique
  handsOnTime  Int        @map("hands_on_time")
  totalTime    Int        @map("total_time")
  notes        String[] 
  servings     Int
  servingMultiplierForNelson Float @map("serving_multiplier_for_nelson") @default(1)
  ingredients RecipeIngredient[]
  ingredientGroups RecipeIngredientGroup[]
  instructions RecipeInstruction[]
  images       RecipeImage[]
  lastUsedInPlanner DateTime? @map("last_used_in_planner")
  excludeFromPlanner Boolean @default(false) @map("exclude_from_planner")

  categories   Category[] @relation("category_recipes")
  planSlots    PlanSlot[] @relation("recipe_plan_slots")
  alternatives PlanSlotAlternative[] @relation("recipe_alternatives")
  logEntryRecipes LogEntryRecipe[]

  @@index([slug])
  @@map("recipes")
}

model Ingredient {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  icon            String?
  brand           String?
  descriptor      String?
  supermarketUrl  String?  @map("supermarket_url")
  calories        Float
  proteins        Float
  fats            Float
  carbs           Float
  categoryId      String   @map("category_id")
  defaultUnitId   String?  @map("default_unit_id")

  category        IngredientCategory @relation(fields: [categoryId], references: [id])
  defaultUnit     Unit?              @relation("ingredient_default_unit", fields: [defaultUnitId], references: [id], onDelete: Restrict)
  recipes         RecipeIngredient[]
  unitConversions IngredientUnit[]
  logIngredients  LogIngredient[]
  groceryIngredient GroceryIngredient?
  ingredientLists IngredientListItem[]

  @@index([categoryId])
  @@index([defaultUnitId])
  @@map("ingredients")
}

model Unit {
  id          String   @id @default(cuid())
  name        String   @unique
  // Optional plural label supports irregular forms (e.g. piece -> pieces).
  namePlural  String?  @map("name_plural")
  
  ingredientUnits IngredientUnit[]
  defaultForIngredients Ingredient[] @relation("ingredient_default_unit")
  recipeIngredients RecipeIngredient[]
  logIngredients LogIngredient[]
  shoppingListItems ShoppingListItem[]

  @@map("units")
}

model IngredientUnit {
  ingredientId  String @map("ingredient_id")
  unitId        String @map("unit_id")
  gramsPerUnit  Float @map("grams_per_unit")
  
  ingredient    Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)
  unit          Unit      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  
  @@id([ingredientId, unitId])
  @@map("ingredient_units")
}

model RecipeIngredient {
  id          String   @id @default(cuid())
  recipeId    String @map("recipe_id")
  groupId     String? @map("group_id")
  position    Int
  ingredientId String @map("ingredient_id")
  unitId      String? @map("unit_id")
  amount      Float? 
  nutritionTarget NutritionTarget @default(BOTH) @map("nutrition_target")
  additionalInfo String? @map("additional_info")

  recipe      Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  group       RecipeIngredientGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  ingredient  Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Restrict)
  unit        Unit?    @relation(fields: [unitId], references: [id], onDelete: Restrict)
  instructionsLinks RecipeInstructionIngredient[]

  @@index([recipeId])
  @@index([recipeId, groupId])
  @@index([ingredientId])  
  @@index([unitId]) 
  @@map("recipe_ingredients")
}

enum NutritionTarget {
  BOTH
  PRIMARY_ONLY
  SECONDARY_ONLY
}

model RecipeIngredientGroup {
  id        String @id @default(cuid())
  recipeId  String @map("recipe_id")
  name      String
  position  Int

  recipe      Recipe             @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredients RecipeIngredient[]

  @@index([recipeId])
  @@unique([recipeId, position])
  @@map("recipe_ingredient_groups")
}

model RecipeInstruction {
  id        String @id @default(cuid())
  recipeId  String @map("recipe_id")
  position  Int
  text      String

  recipe      Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredients RecipeInstructionIngredient[]

  @@index([recipeId])
  @@unique([recipeId, position])
  @@map("recipe_instructions")
}

model RecipeInstructionIngredient {
  instructionId      String @map("instruction_id")
  recipeIngredientId String @map("recipe_ingredient_id")

  instruction      RecipeInstruction @relation(fields: [instructionId], references: [id], onDelete: Cascade)
  recipeIngredient RecipeIngredient  @relation(fields: [recipeIngredientId], references: [id], onDelete: Cascade)

  @@id([instructionId, recipeIngredientId])
  @@index([recipeIngredientId])
  @@map("recipe_instruction_ingredients")
}

model IngredientCategory {
  id        String       @id @default(cuid())
  name      String       @unique
  slug      String       @unique
  sortOrder Int          @default(0) @map("sort_order")

  ingredients                     Ingredient[]
  shoppingLayoutPresetCategories ShoppingLayoutPresetCategory[]
  shoppingListItems              ShoppingListItem[]

  @@map("ingredient_categories")
}

model RecipeImage {
  id        String   @id @default(cuid())
  recipeId  String   @map("recipe_id")
  url       String
  isCover   Boolean  @default(false) @map("is_cover")
  createdAt DateTime @default(now()) @map("created_at")
  
  recipe    Recipe   @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  
  @@index([recipeId])
  @@map("recipe_images")
}

model Log {
  id        String   @id @default(cuid())
  planId    String   @unique @map("plan_id")
  createdAt DateTime @default(now()) @map("created_at")

  plan    Plan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  entries LogEntry[]

  @@map("logs")
}

model LogEntry {
  id        String      @id @default(cuid())
  logId     String      @map("log_id")
  date      DateTime    @db.Date
  mealType  LogMealType @map("meal_type")
  person    LogPerson

  log         Log              @relation(fields: [logId], references: [id], onDelete: Cascade)
  recipes     LogEntryRecipe[]
  ingredients LogIngredient[]

  @@unique([logId, date, mealType, person])
  @@index([logId])
  @@map("log_entries")
}

model LogEntryRecipe {
  id             String   @id @default(cuid())
  entryId        String   @map("entry_id")
  sourceRecipeId String?  @map("source_recipe_id")
  planSlotId     String?  @map("plan_slot_id")
  position       Int      @default(0)

  entry        LogEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)
  sourceRecipe Recipe?         @relation(fields: [sourceRecipeId], references: [id], onDelete: SetNull)
  planSlot    PlanSlot?        @relation(fields: [planSlotId], references: [id], onDelete: SetNull)
  ingredients  LogIngredient[]

  @@index([entryId])
  @@index([sourceRecipeId])
  @@index([planSlotId])
  @@map("log_entry_recipes")
}

model LogIngredient {
  id            String   @id @default(cuid())
  entryId       String   @map("entry_id")
  entryRecipeId String?  @map("entry_recipe_id")
  ingredientId  String?  @map("ingredient_id")
  amount        Float?
  unitId        String?  @map("unit_id")

  entry       LogEntry        @relation(fields: [entryId], references: [id], onDelete: Cascade)
  entryRecipe LogEntryRecipe? @relation(fields: [entryRecipeId], references: [id], onDelete: SetNull)
  ingredient  Ingredient?     @relation(fields: [ingredientId], references: [id], onDelete: SetNull)
  unit        Unit?           @relation(fields: [unitId], references: [id], onDelete: SetNull)

  @@index([entryId])
  @@index([entryRecipeId])
  @@index([ingredientId])
  @@index([unitId])
  @@map("log_ingredients")
}

// Global, app-wide ingredient lists used as a quick-add library on the
// groceries edit page. They are intentionally not scoped to a Plan or a
// ShoppingList so they can be reused across plans.
model IngredientList {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items IngredientListItem[]

  @@map("ingredient_lists")
}

// Many-to-many join between IngredientList and Ingredient. The unique
// constraint guarantees each ingredient appears at most once per list,
// so adding the same ingredient twice is a no-op (idempotent server action).
model IngredientListItem {
  id           String   @id @default(cuid())
  listId       String   @map("list_id")
  ingredientId String   @map("ingredient_id")
  position     Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")

  list       IngredientList @relation(fields: [listId], references: [id], onDelete: Cascade)
  ingredient Ingredient     @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([listId, ingredientId])
  @@index([listId, position])
  @@map("ingredient_list_items")
}
